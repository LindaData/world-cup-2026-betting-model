# Copy this file to .env and fill in keys as you add providers.
# Never commit .env.

# Football-data.org
# Docs: https://www.football-data.org/documentation/api
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_WORLD_CUP_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026

# The Odds API
# Docs: https://the-odds-api.com/liveapi/guides/v4/
THE_ODDS_API_KEY=
ODDS_API_SPORT_KEY=soccer_fifa_world_cup
ODDS_REGIONS=us
ODDS_MARKETS=h2h,spreads,totals
ODDS_ODDS_FORMAT=decimal

# API-Football / API-SPORTS. Recommended first paid provider.
# Docs: https://www.api-football.com/documentation-v3
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=
API_FOOTBALL_SEASON=2026

# Public files. These do not require keys.
OPENFOOTBALL_CUP_URL=https://raw.githubusercontent.com/openfootball/worldcup/master/2026--usa/cup.txt
OPENFOOTBALL_STADIUMS_URL=https://raw.githubusercontent.com/openfootball/worldcup/master/2026--usa/cup_stadiums.csv
INTERNATIONAL_RESULTS_URL=https://raw.githubusercontent.com/martj42/international_results/master/results.csv
INTERNATIONAL_GOALSCORERS_URL=https://raw.githubusercontent.com/martj42/international_results/master/goalscorers.csv
INTERNATIONAL_SHOOTOUTS_URL=https://raw.githubusercontent.com/martj42/international_results/master/shootouts.csv

# Wikimedia pages. No key required.
WIKIMEDIA_API_URL=https://en.wikipedia.org/w/api.php
WIKIMEDIA_PAGES=2026 FIFA World Cup,2026 FIFA World Cup squads,2026 FIFA World Cup officials

# Official FIFA squad PDF. No key required, but stored raw because PDF parsing is handled later.
FIFA_2026_SQUAD_PDF_URL=https://fdp.fifa.org/assetspublic/ce281/pdf/SquadLists-English.pdf

# GDELT news search. No key required.
# Docs/home: https://www.gdeltproject.org/
GDELT_DOC_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_MAX_RECORDS_PER_QUERY=75
GDELT_TIMESPAN=7d
GDELT_NEWS_QUERIES=2026 FIFA World Cup,World Cup 2026 injury,World Cup 2026 suspension,World Cup 2026 squad,World Cup 2026 lineup

# Wikidata/Wikipedia enrichment. No key required.
WIKIDATA_API_URL=https://www.wikidata.org/w/api.php
WIKIPEDIA_API_URL=https://en.wikipedia.org/w/api.php
